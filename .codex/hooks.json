{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/sangwonlee/agent-dashboard/.codex/hooks/pre-commit-check.sh'",
            "timeout": 60
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/sangwonlee/agent-dashboard/.codex/hooks/post-edit-screenshot.sh'",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/sangwonlee/agent-dashboard/.codex/hooks/pre-compact-save.sh'",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/sangwonlee/agent-dashboard/.codex/hooks/stop-notify.sh'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
